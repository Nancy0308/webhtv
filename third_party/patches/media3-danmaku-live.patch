+  private void remeasureLivePending() {
+    if (livePending.isEmpty()) {
+      liveGeneration.incrementAndGet();
+      return;
+    }
+    List<Danmaku> copy = new ArrayList<>(livePending);
+    livePending.clear();
+    int generation = liveGeneration.incrementAndGet();
+    measureLiveBatch(copy, textSizePx, config.textScale, generation);
+  }
+
+  private void measureLiveBatch(List<Danmaku> items, float defaultSizePx, float textScale, int generation) {
+    postToBackground(() -> {
+      for (int i = 0; i < items.size(); i++) {
+        Danmaku danmaku = items.get(i);
+        if (danmaku == null || danmaku.text.isEmpty()) {
+          continue;
+        }
+        float sizePx = danmaku.textSizeSp > 0 ? spToPx(danmaku.textSizeSp * textScale) : defaultSizePx;
+        measurePaint.setTextSize(sizePx);
+        danmaku.measuredWidth = measurePaint.measureText(danmaku.text);
+      }
+      post(() -> addMeasuredLiveBatch(items, generation));
+    });
+  }
+
+  private void addMeasuredLiveBatch(List<Danmaku> items, int generation) {
+    if (released || liveGeneration.get() != generation) {
+      return;
+    }
+    for (int i = 0; i < items.size(); i++) {
+      Danmaku danmaku = items.get(i);
+      if (danmaku == null || danmaku.text.isEmpty()) {
+        continue;
+      }
+      if (livePending.size() >= LIVE_PENDING_CAPACITY) {
+        livePending.removeFirst();
+      }
+      livePending.addLast(danmaku);
+    }
+    if (clock.started && !clock.paused && !livePending.isEmpty()) {
+      postInvalidateOnAnimation();
+    }
+  }
